# RPC endpoints
RPC_CCHAIN_TESTNET=
RPC_DFK_TESTNET=
RPC_BEAM_TESTNET=

# Deployer private key (0x...)
PRIVATE_KEY=

# Snowtrace API key for contract verification (optional but recommended)
# Get it from: https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=

# mpDAO deploy params (optional)
MPDAO_NAME="Meta Pool DAO"
MPDAO_SYMBOL="mpDAO"
MPDAO_INITIAL_SUPPLY=0

# mpDAO mint params (required for mint_mpdao.js)
MINT_ACCOUNT_1=
MINT_ACCOUNT_2=
# MINT_AMOUNT_* se expresa en tokens enteros (human-readable), NO en unidades base.
# Ejemplo: 1000 => mint de 1000 mpDAO completos.
# El script convierte internamente con 6 decimales (parseUnits(valor, 6)).
MINT_AMOUNT_1=1000
MINT_AMOUNT_2=1000

# staking / VP params (stake_for_vp.js)
# STAKE_AMOUNT se expresa en tokens enteros; el script lo convierte con 6 decimales.
STAKE_AMOUNT=1000
STAKE_LOCK_DAYS=30
# Opcional: si no se define, se usa una address aleatoria solo para check VP=0.
USER_B_ADDRESS=

# PolicyGovernor deployment params (deploy_policy_governor.js)
# EPOCH_SECONDS: duración del epoch en segundos (default: 604800 = 7 días)
EPOCH_SECONDS=604800
# QUORUM_MODE: BPS (basis points) o ABSOLUTE
QUORUM_MODE=BPS
# QUORUM_VALUE: si BPS, valor en basis points (5000 = 50%); si ABSOLUTE, cantidad exacta de voting power
QUORUM_VALUE=5000
# VALIDATOR_IDS: IDs de validadores separados por comas (dejar vacío para default [1,2,3,4])
VALIDATOR_IDS=1,2,3,4

# PolicyGovernor voting params (vote_policy.js)
# VOTE_WEIGHTS: pesos de delegación en basis points, separados por comas (deben sumar 10000)
VOTE_WEIGHTS=6000,3000,900,100

# BEAM vault params (Issue 6)
# DEPOSIT_FEE_BPS se cobra sobre el monto depositado (se descuenta del deposito), no adicional.
DEPOSIT_FEE_BPS=100
# Config de epoch para aplicar policy en BEAM (epoch-1 rule).
POLICY_EPOCH_SECONDS=60
# Si es 0, usa timestamp de deploy del vault.
POLICY_START_TIMESTAMP=0
# Opcional: asset existente en BEAM testnet. Si se deja vacio, deploy_beam_vault.js despliega BeamAssetMock.
BEAM_ASSET_ADDRESS=
BEAM_ASSET_NAME="Wrapped BEAM Mock"
BEAM_ASSET_SYMBOL="WBEAM"
BEAM_ASSET_INITIAL_SUPPLY=1000000
# Opcional: PolicyClient real. Si se deja vacio, deploy_beam_vault.js despliega MockPolicyClient.
POLICY_CLIENT_ADDRESS=
# Default policy para MockPolicyClient (solo si se despliega mock).
MOCK_POLICY_EPOCH=1
MOCK_POLICY_VALIDATOR_IDS=1,2,3,4
MOCK_POLICY_WEIGHTS_BPS=2500,2500,2500,2500
# Para smoke de vault (tokens enteros, 18 decimales en el mock asset).
BEAM_VAULT_TEST_DEPOSIT=10

# Policy messaging peers/config (Issue 8)
POLICY_ALLOW=true
# C-Chain network ID (Fuji testnet: 43113, mainnet: 43114)
CCHAIN_ID=43113
# PolicyServer on C-Chain (to be deployed) - serves policies cross-chain
POLICY_SERVER_ADDRESS=
POLICY_GOVERNOR_ADDRESS=
# Vault address on BEAM chain (from deployments.json)
VAULT_ADDRESS=
POLICY_ALLOWED_SOURCE_CHAIN_ID=
POLICY_ALLOWED_SOURCE_SENDER=
POLICY_REQUEST_TARGET_CHAIN_ID=
POLICY_REQUEST_TARGET_SENDER=
POLICY_ALLOWED_CLIENT_CHAIN_ID=
POLICY_ALLOWED_CLIENT_SENDER=

# Demo happy path (Issue 10)
DEMO_POLICY_WEIGHTS_BPS=4000,3000,2000,1000
DEMO_VP_LOCK_DAYS=60
DEMO_VP_STAKE_AMOUNT=1000
DEMO_BEAM_DEPOSIT=100
DEMO_POLICY_EPOCH_SECONDS=3600

# Demo fallback path (Issue 11)
DEMO_FALLBACK_SOURCE_CHAIN_ID=43113
DEMO_FALLBACK_TARGET_CHAIN_ID=4337
DEMO_FALLBACK_KNOWN_EPOCH=1
DEMO_FALLBACK_WEIGHTS_BPS=4000,3000,2000,1000
DEMO_FALLBACK_EPOCH_SECONDS=60
DEMO_FALLBACK_DEPOSIT=100

# Read-state helpers (Issue 12)
STBEAM_VAULT_ADDRESS=
# Opcional: epoch para read_cchain_policy.js (si no se define, usa latestFinalizedEpoch).
READ_POLICY_EPOCH=

# Teleporter/Messenger addresses
TELEPORTER_MESSENGER_CCHAIN=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
TELEPORTER_MESSENGER_DFK=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
TELEPORTER_MESSENGER_BEAM=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
