# RPC endpoints
RPC_CCHAIN_TESTNET=
RPC_DFK_TESTNET=
RPC_BEAM_TESTNET=

# Deployer private key (0x...)
PRIVATE_KEY=

# mpDAO deploy params (optional)
MPDAO_NAME="Meta Pool DAO"
MPDAO_SYMBOL="mpDAO"
MPDAO_INITIAL_SUPPLY=0

# mpDAO mint params (required for mint_mpdao.ts)
MINT_ACCOUNT_1=
MINT_ACCOUNT_2=
# MINT_AMOUNT_* se expresa en tokens enteros (human-readable), NO en unidades base.
# Ejemplo: 1000 => mint de 1000 mpDAO completos.
# El script convierte internamente con 6 decimales (parseUnits(valor, 6)).
MINT_AMOUNT_1=1000
MINT_AMOUNT_2=1000

# Teleporter/Messenger addresses
TELEPORTER_MESSENGER_CCHAIN=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
TELEPORTER_MESSENGER_DFK=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
TELEPORTER_MESSENGER_BEAM=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
