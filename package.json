{
  "name": "avax-gaming-lst-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Phase 1 PoC de mensajeria cross-chain en Avalanche con Hardhat",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "smoke:cchain": "hardhat run scripts/smoke.js --network cchain_testnet",
    "smoke:dfk": "hardhat run scripts/smoke.js --network dfk_testnet",
    "smoke:beam": "hardhat run scripts/smoke.js --network beam_testnet",
    "deploy:mpdao": "hardhat run scripts/deploy_mpdao.js --network cchain_testnet",
    "mint:mpdao": "hardhat run scripts/mint_mpdao.js --network cchain_testnet",
    "deploy:voting-power": "hardhat run scripts/deploy_voting_power.js --network cchain_testnet",
    "stake:vp": "hardhat run scripts/stake_for_vp.js --network cchain_testnet",
    "deploy:beam-vault": "hardhat run scripts/deploy_beam_vault.js --network beam_testnet",
    "smoke:beam-vault": "hardhat run scripts/beam_vault_smoke.js --network beam_testnet",
    "set:policy-client-peers": "hardhat run scripts/set_policy_client_peers.js --network beam_testnet",
    "set:policy-server-peers": "hardhat run scripts/set_policy_server_peers.js --network cchain_testnet",
    "demo:happy-path": "hardhat run scripts/demo_happy_path.js --network cchain_testnet",
    "demo:fallback": "hardhat run scripts/demo_fallback.js --network hardhat",
    "verify:policy-timing": "hardhat run scripts/verify_policy_timing.js --network hardhat",
    "read:cchain-policy": "hardhat run scripts/read_cchain_policy.js --network cchain_testnet",
    "read:beam-vault": "hardhat run scripts/read_beam_vault_and_buckets.js --network beam_testnet",
    "deploy:all": "hardhat run scripts/deploy-all.js",
    "send:ping": "hardhat run scripts/send-ping.js",
    "send:triangle": "hardhat run scripts/send-triangle.js",
    "read:state": "hardhat run scripts/read-state.js",
    "verify:cchain": "hardhat run scripts/verify_contracts.js --network cchain_testnet",
    "verify:beam": "hardhat run scripts/verify_contracts.js --network beam_testnet",
    "vault:use-mock": "USE_MOCK_CLIENT=true hardhat run scripts/update_vault_policy_client.js --network beam_testnet",
    "vault:use-real": "USE_MOCK_CLIENT=false hardhat run scripts/update_vault_policy_client.js --network beam_testnet",
    "flatten:mock-client": "hardhat flatten contracts/mocks/MockPolicyClient.sol > MockPolicyClient_flat.sol && echo 'Flattened to MockPolicyClient_flat.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "hardhat": "^2.28.6"
  }
}
